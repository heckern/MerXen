# Root directory for pipeline outputs
MERXEN_OUTPUT_ROOT=/path/to/output

# Optional Python-side ProSeg default. The Nextflow workflow primarily uses
# workflows/nextflow.config for ProSeg search/install settings.
MERXEN_PROSEG_INSTALL_PATH=/usr/bin/proseg

# Maximum system RAM in GB (for memory-aware tiling)
MERXEN_MAX_RAM_GB=600
