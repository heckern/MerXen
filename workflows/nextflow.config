params {
    samplesheet = null
    outdir = "./results"
    proseg_binary = null
    force_spatialdata_build = false

    // Cellpose defaults
    cellpose_model_type = "cyto3"
    cellpose_flow_threshold = 0.8
    cellpose_cellprob = -5.0
    cellpose_gpu = true
    cellpose_diameter = null
    cellpose_tile_overlap = 0.15
    cellpose_bsize = 256

    // ProSeg defaults
    proseg_samples = 1200
    proseg_voxel_size = 0.5
    proseg_burnin_voxel_size = 1.0
    proseg_nuclear_reassignment_prob = 0.25
    proseg_diffusion_probability = 0.25
    proseg_cell_compactness = 0.04
    proseg_num_threads = 64
    default_merscope_voxel_layers = 7
    default_xenium_voxel_layers = 2

    // Platform defaults
    xenium_min_qv = 20.0

    // Memory defaults
    max_ram_gb = 600
    warn_ram_gb = 560
    transcript_chunk_rows = 1000000
}

executor {
    name = "local"
    cpus = 64
    memory = "600 GB"
}

process {
    conda = "${projectDir}/../environment.yml"

    withName: "BUILD_SPATIALDATA" {
        cpus = 8
        memory = "200 GB"
    }
    withName: "SEGMENT" {
        cpus = 64
        memory = "500 GB"
    }
    withName: "ENRICH" {
        cpus = 16
        memory = "200 GB"
    }
    withName: "QC" {
        cpus = 8
        memory = "100 GB"
    }
    withName: "COMPARE" {
        cpus = 8
        memory = "200 GB"
    }
    withName: "VISUALIZE" {
        cpus = 8
        memory = "200 GB"
    }
}

conda {
    enabled = true
}

report {
    overwrite = true
}

timeline {
    overwrite = true
}

trace {
    overwrite = true
}
