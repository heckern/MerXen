params {
    samplesheet = null
    outdir = "./results"
    proseg_binary = null
    force_spatialdata_build = false
    start_stage = "build_spatialdata"
    stop_stage = "clustering_squidpy"
    only_stage = null

    // Cellpose defaults
    cellpose_model_type = "cyto3"
    cellpose_flow_threshold = 0.8
    cellpose_cellprob = -5.0
    cellpose_gpu = true
    cellpose_diameter = null
    cellpose_tile_overlap = 0.15
    cellpose_bsize = 256

    // ProSeg defaults
    proseg_samples = 1200
    proseg_voxel_size = 0.5
    proseg_burnin_voxel_size = 1.0
    proseg_nuclear_reassignment_prob = 0.25
    proseg_diffusion_probability = 0.25
    proseg_cell_compactness = 0.04
    proseg_num_threads = 75
    default_merscope_voxel_layers = 7
    default_xenium_voxel_layers = 2

    // Platform defaults
    xenium_min_qv = 20.0

    // Optional cross-section alignment defaults
    enable_alignment = false
    alignment_spateo_mode = "SN-S"
    alignment_device = "auto"
    alignment_dtype = "float32"
    alignment_selected_mode = "nonrigid"
    alignment_max_iter = 360
    alignment_nonrigid_start_iter = 220
    alignment_beta = 0.005
    alignment_lambda_vf = 3000.0
    alignment_k = 15
    alignment_partial_robust_level = 100
    alignment_allow_flip = true
    alignment_svi_mode = false
    alignment_n_sampling = 1000
    alignment_sparse_top_k = 512
    alignment_sparse_calculation_mode = true
    alignment_use_chunk = true
    alignment_chunk_capacity = 1
    alignment_use_hvg = false
    alignment_n_top_genes = 100
    alignment_use_pca = true
    alignment_n_pcs = 50
    alignment_max_alignment_cells = 35000
    alignment_seed = 21
    alignment_rbf_neighbors = 64
    alignment_rbf_smoothing = 0.0
    alignment_max_nonrigid_anchors = 5000
    alignment_pytorch_cuda_alloc_conf = "expandable_segments:True,max_split_size_mb:256"
    alignment_qc_grid_rows = 10
    alignment_qc_grid_cols = 10

    // Scanpy/Squidpy clustering defaults
    clustering_squidpy_drop_control_features = true
    clustering_squidpy_min_counts = 10
    clustering_squidpy_min_cells = 5
    clustering_squidpy_normalize_target_sum = null
    clustering_squidpy_normalize_exclude_highly_expressed = false
    clustering_squidpy_normalize_max_fraction = 0.05
    clustering_squidpy_n_pcs = 60
    clustering_squidpy_n_neighbors = 30
    clustering_squidpy_leiden_resolution = 0.5
    clustering_squidpy_umap_min_dist = 0.3
    clustering_squidpy_umap_spread = 1.0
    clustering_squidpy_random_seed = 0
    clustering_squidpy_spatial_point_size = 0.5
    clustering_squidpy_figure_dpi = 180
    clustering_squidpy_use_gpu = true

    // Local MapMyCells defaults (opt in with --stop_stage mapmycells)
    mapmycells_reference_mode = "both"
    mapmycells_marker_lookup_path = "/media/mathieubo/SSD2/MerXen/mapmycells/query_markers.n10.20240221800.json"
    mapmycells_precomputed_stats_path = "/media/mathieubo/SSD2/MerXen/mapmycells/precomputed_stats.siletti.training.h5"
    mapmycells_region_name = "frontal_a44_a45_a46_a32_acc"
    mapmycells_region_labels = ["Human A44-A45", "Human A46", "Human A32", "Human ACC"]
    mapmycells_region_cache_dir = "/media/mathieubo/SSD2/MerXen/mapmycells"
    mapmycells_region_min_cells_per_leaf = 10
    mapmycells_region_force_rebuild = false
    mapmycells_region_query_markers_n_per_utility = 10
    mapmycells_drop_level = null
    mapmycells_normalization = "raw"
    mapmycells_bootstrap_factor = 0.9
    mapmycells_bootstrap_iteration = 100
    mapmycells_n_processors = 8
    mapmycells_chunk_size = null
    mapmycells_rng_seed = 0
    mapmycells_max_gb = null
    mapmycells_tmp_dir = null
    mapmycells_cloud_safe = false
    mapmycells_flatten = false
    mapmycells_verbose_csv = false
    mapmycells_plots_only = false
    mapmycells_query_layer = "counts"
    mapmycells_gene_id_column = "ensembl_id"
    mapmycells_obs_id_column = null

    // Memory defaults
    max_ram_gb = 600
    warn_ram_gb = 560
    transcript_chunk_rows = 1000000
}

executor {
    name = "local"
    cpus = 75
    memory = "600 GB"
}

process {
    conda = "${projectDir}/../environment.yml"

    withName: "BUILD_SPATIALDATA" {
        cpus = 8
        memory = "200 GB"
    }
    withName: "SEGMENT" {
        cpus = 75
        memory = "500 GB"
    }
    withName: "ENRICH" {
        cpus = 16
        memory = "200 GB"
    }
    withName: "QC" {
        cpus = 8
        memory = "100 GB"
    }
    withName: "ALIGN" {
        cpus = 16
        memory = "300 GB"
        maxForks = 1
    }
    withName: "ALIGN_QC" {
        cpus = 8
        memory = "150 GB"
    }
    withName: "COMPARE" {
        cpus = 8
        memory = "200 GB"
    }
    withName: "VISUALIZE" {
        cpus = 8
        memory = "200 GB"
    }
    withName: "CLUSTERING_SQUIDPY" {
        cpus = 8
        memory = "200 GB"
    }
    withName: "MAPMYCELLS" {
        cpus = 8
        memory = "200 GB"
    }
}

conda {
    enabled = true
}

report {
    enabled = true
    file = "${params.outdir}/nextflow/report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.outdir}/nextflow/timeline.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/nextflow/trace.tsv"
    overwrite = true
    sep = '\t'
    fields =
        'task_id,hash,native_id,process,tag,name,status,exit,attempt,' +
        'cpus,memory,submit,start,complete,duration,realtime,%cpu,' +
        'peak_rss,peak_vmem,rchar,wchar,read_bytes,write_bytes,workdir'
}
